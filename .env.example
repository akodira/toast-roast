# Copy to .env.local for local dev.
# On Railway, set these as Variables instead (Project → Variables).
JWT_SECRET=change-me-to-a-long-random-string

# Supabase Postgres connection string.
# Supabase dashboard → Project Settings → Database → Connection string → URI
# Use the "Transaction pooler" (port 6543) connection string for serverless/
# many-short-lived-connections hosting like Railway; use the direct connection
# (port 5432) only if you disable pgbouncer-incompatible features (none used here).
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Leave true for Supabase (always requires SSL). Only set false for a local
# Postgres instance without SSL configured.
PGSSL=true
